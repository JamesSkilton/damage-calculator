  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx --fix",
    "format": "prettier --write .",
